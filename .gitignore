# ============================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================================
# Claude Code internal rules (not for open-source consumers)
# ============================================================================
CLAUDE.md

# ============================================================================
# Raw capture data (privacy + size)
# ============================================================================
data/

# ============================================================================
# Pipeline outputs — generated by 01-05 scripts. Keep the folder structure
# via .gitkeep so default CLI paths work on a fresh clone.
# ============================================================================
output/*
!output/.gitkeep

# ============================================================================
# Large third-party model assets — download via README §2.1 instructions
# ============================================================================
assets/hamer/_DATA/
assets/dex-urdf/
*.tar.gz

# ============================================================================
# Legacy / archived work (ArUco calibration pipeline, training experiments)
# Kept locally for reference; not part of the open-source main line.
# ============================================================================
scripts/legacy/
tests/legacy/

# ============================================================================
# One-off diagnostic / debug artifacts
# ============================================================================
MJMODEL.TXT
MUJOCO_LOG.TXT

# ============================================================================
# Orbbec SDK runtime log (auto-generated on every pyorbbecsdk2 init)
# ============================================================================
Log/

# ============================================================================
# MuJoCo sim scene cache (replay/sim/mujoco_dex generates host-dependent
# absolute meshdir paths into these; never commit)
# ============================================================================
replay/sim/scenes/_*
